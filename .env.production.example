# ============================================================
# Production env · 复制为 .env.local 用于本地真实测试；
# 部署时把这些 key 在云厂商后台配置（Vercel Dashboard / 腾讯云）
# ============================================================

# ⭐ 必填：Anthropic API key（首选方案）
# 申请地址：https://console.anthropic.com/settings/keys
# 没有这个 key，所有 LLM 调用会走本地 mock（看起来像演示但内容固定）
ANTHROPIC_API_KEY=sk-ant-api03-...

# 可选：模型选择
# - claude-haiku-4-5-20251001  快速 / 便宜 / 用于常规推演（推荐）
# - claude-sonnet-4-5            质量更高 / 用于终局主预言卡
# 默认 sonnet-4-5（路由层会按 agent 智能选择）
ANTHROPIC_MODEL=claude-sonnet-4-5

# ⚠️ 不要打开 CLI fallback（仅本地 demo 用，慢 6-10 倍）
# ALLOW_CLI_FALLBACK=1

# ⚠️ OAuth token 已被 Anthropic 永久封禁（2026/5/12 起）
# 不要尝试以下任何 OAuth 路径：
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...
